# 目录配置
UPLOAD_DIR="data/temp_uploads"
OUTPUT_DIR="data/outputs"

# MinIO 配置
MINIO_ENDPOINT="192.168.14.129:9000"
MINIO_ACCESS_KEY="admin"
MINIO_SECRET_KEY="1234567890"
MINIO_SECURE=false
MINIO_BUCKET_NAME="uav-system"