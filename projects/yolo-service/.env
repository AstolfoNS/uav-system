# 服务基础配置
PROJECT_NAME="UAV Detection Service [DEV]"
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX="/api/v1"
DEBUG=true

# 并发与性能配置
WORKERS=3

# 跨域配置
ALLOWED_ORIGINS=["*"]

# 模型配置
